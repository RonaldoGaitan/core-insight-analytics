# Production Environment Variables
DATABASE_URL=postgresql://postgres:your-production-password@your-production-db-host:5432/postgres
SUPABASE_URL=https://your-production-supabase.supabase.co
SUPABASE_KEY=your-production-supabase-key
ANTHROPIC_API_KEY=your-production-anthropic-key

# OAuth Configuration
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Monitoring
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key

# Security
SECRET_KEY=your-production-secret-key-change-this
ALLOWED_ORIGINS=https://coreinsight.solutions,https://www.coreinsight.solutions
